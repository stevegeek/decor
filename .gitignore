# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

.DS_Store

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# test/dummy keeps its own tmp/log/storage entries further down; nothing
# at the gem root should generate runtime files, but ignore defensively.
/log/
/tmp/
node_modules/

# Built gem artifacts.
*.gem

/app/assets/builds/*
!/app/assets/builds/.keep
!/app/assets/builds/decor.css
!/app/assets/builds/decor.js
!/app/assets/builds/decor.js.map
!/app/assets/builds/decor.d.ts

# Claude Code skills directory (generated by `bin/rails generate vident:install`).
# Project-local agent assets — not part of the library.
.claude/

# Decor library stuff, comment out if you clone for your app

# test/dummy runtime artifacts
/test/dummy/log/*
/test/dummy/storage/*
/test/dummy/tmp/*
!/test/dummy/log/.keep
!/test/dummy/storage/.keep
!/test/dummy/tmp/.keep

# End of Decor library stuff
