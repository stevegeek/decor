<%= render ::Decor::Daisy::Modals::Modal.new(start_shown: true) do %>
  <%= render ::Decor::Daisy::Modals::ModalLayout.new(
        icon: "alert-triangle",
        title: "Confirm Action",
        description: "Are you sure you want to proceed? This action cannot be undone.",
        color: :warning
      ) do %>
    <div class="decor:flex decor:gap-4 decor:justify-end decor:mt-4">
      <%= render ::Decor::Daisy::Modals::ModalCloseButton.new(label: "Cancel", style: :ghost) %>
      <%= render ::Decor::Daisy::Button.new(label: "Confirm", color: :warning) %>
    </div>
  <% end %>
<% end %>
