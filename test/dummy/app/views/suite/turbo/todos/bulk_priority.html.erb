<%# Modal body fragment: decor Suite form to set priority for the selected todos.
    Loaded via GET into the Suite Modal body (fetchAndInjectBody), submitted under
    Turbo Drive (turbo: true). Built with the decor Form component + form builder. %>

<% selected_count = @selected_ids.size %>

<%= render ::Decor::Suite::Forms::Form.new(
      url: bulk_priority_submit_suite_turbo_todos_path,
      http_method: :post,
      local: true,
      turbo: true
    ) do |form| %>

  <p class="decor:mb-4">
    Set priority for <strong><%= selected_count %></strong>
    selected <%= selected_count == 1 ? "todo" : "todos" %>.
  </p>

  <%# Selected todo IDs (todo_ids[]) via the Rails form helper rather than raw
      <input> HTML. `id: nil` avoids duplicate element ids across the set. %>
  <% @selected_ids.each do |id| %>
    <%= hidden_field_tag "todo_ids[]", id, id: nil %>
  <% end %>

  <%= form.builder.select :priority,
        [["Low", "low"], ["Medium", "medium"], ["High", "high"]],
        {label: "New priority"} %>

  <%# Submit in the form's footer slot — separated + right-aligned in the modal. %>
  <% form.with_actions do %>
    <%= form.builder.submit "Apply" %>
  <% end %>
<% end %>
