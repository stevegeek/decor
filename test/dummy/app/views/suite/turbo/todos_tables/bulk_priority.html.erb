<%# Modal body fragment: priority-select form for the selected todos.
    Loaded via GET into the Suite Modal body (fetchAndInjectBody).
    Returned as a bare HTML fragment (no layout). %>

<% selected_count = @selected_ids.size %>

<%= form_with(url: bulk_priority_submit_suite_turbo_todos_table_path, method: :post, local: true) do |f| %>

  <p style="margin-bottom:1rem">
    Set priority for <strong><%= selected_count %></strong>
    selected <%= selected_count == 1 ? "todo" : "todos" %>.
  </p>

  <%# Hidden inputs carrying the selected todo IDs. %>
  <% @selected_ids.each do |id| %>
    <%= f.hidden_field :todo_ids, multiple: true, value: id %>
  <% end %>

  <div style="margin-bottom:1rem">
    <label for="bulk_priority_select" style="display:block;margin-bottom:0.25rem">New priority</label>
    <%= f.select :priority, [["Low", "low"], ["Medium", "medium"], ["High", "high"]],
                 {}, { id: "bulk_priority_select", name: "priority" } %>
  </div>

  <%= f.submit "Apply", id: "bulk_priority_submit" %>
<% end %>
