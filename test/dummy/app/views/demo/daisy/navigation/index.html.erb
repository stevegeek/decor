<%# The SideNavbar renders its own fixed desktop rail + (hidden) mobile drawer. %>
<%= render Demo::SidebarExample.new %>

<div class="decor:lg:pl-72 decor:p-6" data-controller="demo-triggers">
  <%= render ::Decor::Suite::PageHeader.new(title: "Navigation", subtitle: "Side navbar: mobile drawer, collapse, search") %>

  <%# Hamburger: dispatches the SideNavbar's scoped toggle event (as a top
      navbar would). On lg the desktop rail is visible; the drawer overlays. %>
  <%= render ::Decor::Daisy::Button.new(
        label: "Open mobile menu", color: :primary, id: "open-mobile-menu",
        html_options: {type: "button", class: "decor:mt-4", data: {
          action: "click->demo-triggers#fire",
          "demo-triggers-event-param": "decor--daisy--nav--side-navbar:toggleMobileMenu"
        }}) %>

  <p class="decor:mt-4 decor:suite-description decor:text-gray-500">
    On wide screens the rail is on the left — use its collapse button and search.
    The "Open mobile menu" button opens the drawer overlay.
  </p>
</div>
