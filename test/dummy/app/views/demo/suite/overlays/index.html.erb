<%# Suite toast host, pinned top-right (dispatched via window events). %>
<%= render ::Decor::Suite::NotificationManager.new(position: :top_right) %>

<%= render ::Decor::Suite::Page.new do |page| %>
  <% page.with_header do %>
    <%= render ::Decor::Suite::PageHeader.new(title: "Overlays & Notifications", subtitle: "Dynamic-behaviour harness") %>
  <% end %>

  <%= render ::Decor::Suite::PageSection.new(title: "Notifications (toast placement)", separator: true) do %>
    <div data-controller="demo-triggers" class="decor:flex decor:gap-2 decor:flex-wrap decor:items-center">
      <%= render ::Decor::Suite::Button.new(
            label: "Show success toast", color: :primary, id: "notify-success",
            html_options: {type: "button", data: {
              action: "click->demo-triggers#notify",
              "demo-triggers-title-param": "Saved",
              "demo-triggers-body-param": "Your changes were saved.",
              "demo-triggers-timeout-param": "8000"
            }}) %>
      <%= render ::Decor::Suite::Button.new(
            label: "Show error toast", color: :error, id: "notify-error",
            html_options: {type: "button", data: {
              action: "click->demo-triggers#notify",
              "demo-triggers-title-param": "Error",
              "demo-triggers-body-param": "Something went wrong.",
              "demo-triggers-timeout-param": "8000"
            }}) %>
      <%= render ::Decor::Suite::Button.new(
            label: "Dismiss all", style: :outlined, color: :base, id: "notify-dismiss-all",
            html_options: {type: "button", data: {action: "click->demo-triggers#dismissAll"}}) %>
    </div>
  <% end %>

  <%= render ::Decor::Suite::PageSection.new(title: "Tooltip (popover anchored to its target)", separator: true) do %>
    <%= render ::Decor::Suite::Tooltip.new(tip_text: "I'm anchored to my trigger (Floating UI)", position: :top) do %>
      <%= render ::Decor::Suite::Button.new(label: "Hover or focus me", style: :outlined, color: :base, id: "tooltip-trigger", html_options: {type: "button"}) %>
    <% end %>
  <% end %>

  <%= render ::Decor::Suite::PageSection.new(title: "Dropdown (native popover, CSS-anchored to trigger)", separator: true) do %>
    <%= render Demo::DropdownExample.new %>
  <% end %>

  <%= render ::Decor::Suite::PageSection.new(title: "Flash", separator: true) do %>
    <%= render ::Decor::Suite::Flash.new(id: "demo-flash", color: :success, text: "Saved successfully.") %>
  <% end %>
<% end %>
