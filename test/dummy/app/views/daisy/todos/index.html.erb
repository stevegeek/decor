<%= render ::Decor::Daisy::Page.new(flash_data: flash) do |page| %>
  <% page.with_header do %>
    <%= render ::Decor::Daisy::PageHeader.new(title: "Daisy Todos", subtitle: "Turbo Drive") %>
  <% end %>

  <% if @todo.errors.any? %>
    <%= render ::Decor::Daisy::Flash.new(id: "daisy-errors", color: :error, text: @todo.errors.full_messages.to_sentence) %>
  <% end %>

  <%= render ::Decor::Daisy::PageSection.new(title: "Todos", separator: true) do %>
    <ul id="daisy-todos">
      <%= render partial: "todos/todo", collection: @todos, as: :todo %>
    </ul>
  <% end %>

  <%= render ::Decor::Daisy::PageSection.new(title: "Add a todo", separator: true) do %>
    <%= render ::Decor::Daisy::Forms::Form.new(model: @todo, url: daisy_todos_path, local: true, turbo: true) do |form_component| %>
      <%= form_component.builder.text_field :title, label: "Title", required: true %>
      <%= form_component.builder.text_area :description, label: "Description", rows: 3 %>
      <%= form_component.builder.select :priority, [["Low", "low"], ["Medium", "medium"], ["High", "high"]], {label: "Priority"} %>
      <%= form_component.builder.submit "Create Todo", html_options: { data: { "turbo-confirm": "Are you sure you want to create this todo?" } } %>
    <% end %>
  <% end %>
<% end %>
