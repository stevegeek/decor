<!DOCTYPE html>
<html>
  <head>
    <title>Todos Harness</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= turbo_refreshes_with method: :morph, scroll: :preserve %>
    <%= stylesheet_link_tag "decor", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <%# Instrument block: data-turbo-permanent so morphs preserve the logged
        events and the document-level listeners. %>
    <div id="instrument" data-turbo-permanent data-controller="event-logger">
      <div id="morph-sentinel" data-event-logger-target="sentinel"></div>
      <ol id="event-log"></ol>
    </div>
    <main>
      <%= yield %>
    </main>
  </body>
</html>
