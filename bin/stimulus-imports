#!/usr/bin/env ruby
# frozen_string_literal: true

require "pathname"

ROOT = Pathname.new(File.expand_path("..", __dir__))
SRC = ROOT.join("app/javascript/controllers/decor")
OUT = ROOT.join("app/javascript/decor/controllers.js")

abort "Source dir not found: #{SRC}" unless SRC.directory?

# Derive Vident's Stimulus identifier from a controller file's relative path
# under app/javascript/controllers/decor/.
#
# Examples:
#   "suite/tooltip_controller.js"            -> "decor--suite--tooltip"
#   "daisy/click_to_copy_controller.js"      -> "decor--daisy--click-to-copy"
#   "daisy/forms/date_calendar_controller.js" -> "decor--daisy--forms--date-calendar"
#   "progress_animation_controller.js"       -> "decor--progress-animation"
def vident_identifier_for(rel_path)
  base = rel_path.sub(/\.(ts|js)$/, "").sub(/_controller$/, "")
  segments = base.split("/").map { |seg| seg.tr("_", "-") }
  (["decor"] + segments).join("--")
end

# Disambiguate JS export names when basenames collide (e.g. daisy/click_to_copy
# and suite/click_to_copy). When unique, use just the basename; otherwise prefix
# with the parent directory segments.
candidates = []
seen_basenames = Hash.new(0)

SRC.glob("**/*_controller.{ts,js}").sort.each do |path|
  rel = path.relative_path_from(SRC).to_s.sub(/\.(ts|js)$/, "")
  basename_export = path.basename.to_s.sub(/\.(ts|js)$/, "").split("_").map(&:capitalize).join
  seen_basenames[basename_export] += 1
  candidates << [rel, basename_export]
end

entries = candidates.map do |rel, basename_export|
  export_name = if seen_basenames[basename_export] > 1
    rel.split("/").map { |part| part.split("_").map(&:capitalize).join }.join
  else
    basename_export
  end
  identifier = vident_identifier_for("#{rel}.js")
  import_path = "../controllers/decor/#{rel}"
  [export_name, import_path, identifier]
end

imports = entries.map { |name, path, _| %(import #{name} from "#{path}";) }.join("\n")
map_entries = entries.map { |name, _, ident| %(  "#{ident}": #{name},) }.join("\n")

File.write(OUT, <<~JS)
  // Auto-generated by bin/stimulus-imports — DO NOT EDIT MANUALLY.
  #{imports}

  export const CONTROLLERS = {
  #{map_entries}
  };
JS

puts "Generated #{OUT} with #{entries.length} controller registrations."
