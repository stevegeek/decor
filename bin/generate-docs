#!/usr/bin/env ruby
# frozen_string_literal: true

# Regenerates test/components/docs/03_component_reference.md.erb by
# introspecting every loaded Decor::{Daisy,Suite}::* component class via
# Literal's properties_index. Run from the gem root:
#
#   bin/generate-docs

require "pathname"

ROOT = Pathname.new(__dir__).join("..").expand_path
ENV["BUNDLE_GEMFILE"] = ROOT.join("test/dummy/Gemfile").to_s
ENV["RAILS_ENV"] ||= "production"
ENV["SECRET_KEY_BASE"] ||= "doc_generation_placeholder"

require "bundler/setup"
require ROOT.join("test/dummy/config/environment").to_s

# Properties contributed by the Vident / PhlexComponent base — filtered
# out of per-component prop listings so the docs surface only what each
# component adds.
BASE_PROPS = %i[
  element_tag id classes html_options
  stimulus_controllers stimulus_actions stimulus_targets stimulus_outlets
  stimulus_outlet_host stimulus_values stimulus_params stimulus_classes
].freeze

SHARED_PROPS = %i[size color style].freeze

def component_classes
  ObjectSpace.each_object(Class).select do |c|
    next false unless c < ::Decor::PhlexComponent
    name = c.name.to_s
    next false unless name.start_with?("Decor::Daisy::", "Decor::Suite::") || name == "Decor::Icon"
    # Drop abstract bases under Decor::Components::* if any leak in via
    # subclassing (none should — gemspec-shipped concrete classes only).
    !name.include?("::Components::")
  end.sort_by(&:name)
end

def category_for(klass)
  name = klass.name
  case name
  when /::Forms::/    then "Forms"
  when /::Modals::/   then "Modals"
  when /::Tables::/   then "Tables"
  when /::Nav::/      then "Navigation"
  when /::Chat::/     then "Chat"
  when /::AiChat::/   then "AI chat"
  when /::SettingsList::/ then "Settings"
  else "Core"
  end
end

def skin_for(klass)
  return "Skinless" if klass.name == "Decor::Icon"
  klass.name.split("::")[1] # Daisy / Suite
end

def short_name(klass)
  klass.name.sub(/^Decor::(Daisy|Suite)::/, "").sub(/^Decor::/, "")
end

def describe_type(type)
  case type
  when Class then type.name
  else
    s = type.inspect
    # Literal type matchers can render very long; truncate for the docs.
    (s.length > 80) ? "#{s[0, 77]}…" : s
  end
end

def describe_default(prop)
  return nil unless prop.respond_to?(:default) && !prop.default.nil?
  default = prop.default
  case default
  when Proc, Method then nil
  when String       then default.inspect
  when Symbol       then default.inspect
  when true, false  then default.inspect
  when Numeric      then default.inspect
  else default.inspect[0, 40]
  end
end

def own_props(klass)
  inherited = klass.superclass.respond_to?(:literal_properties) ? klass.superclass.literal_properties.properties_index.keys.to_set : Set.new
  klass.literal_properties.properties_index.reject { |name, _| BASE_PROPS.include?(name) || SHARED_PROPS.include?(name) || inherited.include?(name) }
end

def shared_prop_defaults(klass)
  defaults = {}
  SHARED_PROPS.each do |key|
    prop = klass.literal_properties.properties_index[key]
    next unless prop
    val = describe_default(prop)
    defaults[key] = val if val
  end
  defaults
end

def slot_methods(klass)
  return [] unless klass.respond_to?(:registered_slots)
  klass.registered_slots.keys.map(&:to_s).sort
rescue
  klass.instance_methods(false).grep(/\Awith_/).map(&:to_s).sort
end

def slug(klass)
  short_name(klass).downcase.gsub(/[^a-z0-9]/, "")
end

def render_component_section(klass)
  out = +""
  name = klass.name
  out << "### #{name}\n\n"
  out << "<span id=\"#{slug(klass)}\"></span>\n\n"

  out << "**Basic usage:**\n\n"
  out << "```ruby\nrender #{name}.new\n```\n\n"

  props = own_props(klass)
  if props.any?
    out << "**Props:**\n\n"
    props.each do |pname, prop|
      type_str = describe_type(prop.type)
      default_str = describe_default(prop)
      line = "- `#{pname}` (#{type_str})"
      line << " — default: `#{default_str}`" if default_str
      out << line << "\n"
    end
    out << "\n"
  end

  defaults = shared_prop_defaults(klass)
  if defaults.any?
    out << "**Shared-prop defaults:** "
    out << defaults.map { |k, v| "`#{k}: #{v}`" }.join(", ")
    out << "\n\n"
  end

  slots = slot_methods(klass)
  if slots.any?
    out << "**Slots:** "
    out << slots.map { |s| "`#{s}`" }.join(", ")
    out << "\n\n"
  end

  out << "---\n\n"
  out
end

classes = component_classes
grouped = classes.group_by { |c| [skin_for(c), category_for(c)] }

skin_order = ["Daisy", "Suite", "Skinless"]
category_order = ["Core", "Forms", "Tables", "Modals", "Navigation", "Chat", "AI chat", "Settings"]

output = +<<~HEADER
  ---
  title: Component Reference
  label: Component Reference
  ---

  # Component Reference

  Autogenerated reference for every shipped component, grouped by skin
  (Daisy and Suite) then by family. Regenerate with `bin/generate-docs`.

  - **Daisy skin** (`Decor::Daisy::*`) — daisyUI semantic styling, generally suited to admin / internal UI.
  - **Suite skin** (`Decor::Suite::*`) — bespoke design tokens (numbered shades, hairlines, custom radii + typography), suited to customer-facing UI that wants a distinct identity.
  - **Skinless** (`Decor::Icon`) — single class used by both skins.

  Both skins share an abstract base under `Decor::Components::*` that owns the prop API; the props listed below are each concrete component's own additions on top of the inherited shared props (`size`, `color`, `style`) and the Vident base props.

  ---

HEADER

skin_order.each do |skin|
  skin_classes = grouped.select { |(s, _), _| s == skin }.values.flatten
  next if skin_classes.empty?

  output << "## #{skin}\n\n"

  category_order.each do |category|
    cat_classes = grouped[[skin, category]] || []
    next if cat_classes.empty?

    output << "### #{category}\n\n"
    cat_classes.sort_by(&:name).each do |klass|
      output << "- [`#{klass.name}`](##{slug(klass)})\n"
    end
    output << "\n"
  end
end

output << "---\n\n"

skin_order.each do |skin|
  skin_classes = grouped.select { |(s, _), _| s == skin }.values.flatten
  next if skin_classes.empty?

  skin_classes.sort_by(&:name).each do |klass|
    output << render_component_section(klass)
  end
end

target = ROOT.join("test/components/docs/03_component_reference.md.erb")
target.write(output)
puts "Wrote #{target.relative_path_from(ROOT)} — #{classes.length} components."
